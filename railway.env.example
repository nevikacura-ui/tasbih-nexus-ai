# ============================================
# Railway environment variables — Tasbih.ai
# Paste this whole block into Railway → Variables → Raw Editor.
# Replace every YOUR_* placeholder with real values.
# ============================================

# ── MongoDB Atlas ──
# 1. cloud.mongodb.com → cluster → Connect → "Drivers".
# 2. Network Access → IP Access List → Add 0.0.0.0/0 (Railway uses dynamic IPs).
# 3. Escape any `@` / `:` / `/` / `?` / `#` in your password with URL-encoding.
MONGO_URL=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
DB_NAME=tasbih

# ── Server ──
PORT=8000
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# ── App URLs ──
# First deploy: set both to the Railway domain (e.g. https://web-production-xxxx.up.railway.app).
# After you attach the custom domain, swap to https://www.tasbih.ai.
REACT_APP_BACKEND_URL=https://YOUR_APP.up.railway.app
REACT_APP_PUBLIC_URL=https://YOUR_APP.up.railway.app
FRONTEND_URL=https://YOUR_APP.up.railway.app

# CORS — comma-separated allow-list. Include the Railway domain AND custom domains.
# When unset, the backend falls back to `*` (fine for the guest-token API surface).
CORS_ORIGINS=https://YOUR_APP.up.railway.app,https://www.tasbih.ai,https://tasbih.ai

# ── 3rd-party integrations (already used by the app) ──
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY
ELEVENLABS_API_KEY=YOUR_KEY
GOOGLE_MAPS_API_KEY=YOUR_KEY
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_WEB_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_SECRET
RESEND_API_KEY=re_YOUR_KEY
RESEND_FROM=Tasbih.ai <onboarding@resend.dev>
MSG91_AUTH_KEY=YOUR_KEY
MSG91_TEMPLATE_ID=YOUR_TEMPLATE_ID

# ── Feature flags ──
# Set to "true" to expose WhatsApp/MSG91 OTP; leave "false" for launch.
ENABLE_OTP_LOGIN=false
